# Set default behavior to automatically handle line endings.
# This will normalize all text files to LF in the repository but check them out
# with the OS-native line endings (CRLF on Windows, LF on Linux/macOS).
* text=auto

# Explicitly declare text files to ensure they are handled correctly.
*.html    text
*.css     text
*.js      text
*.jsx     text
*.ts      text
*.tsx     text
*.json    text
*.md      text
*.txt     text
*.yml     text
*.yaml    text
*.toml    text
*.svg     text

# Force shell scripts to always use LF for compatibility with Linux/macOS environments.
*.sh      eol=lf

# Denote files that are binary and should not be modified by Git.
*.png     binary
*.jpg     binary
*.jpeg    binary
*.gif     binary
*.ico     binary
*.pdf     binary
*.zip     binary
*.gz      binary
*.woff    binary
*.woff2   binary